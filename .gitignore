# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv
worktrees/
queue/

# Agent prompt files (generated per-session by launchers)
CLAUDE.md
AGENTS.md

# Experimental code/artifacts
dev/

# Autoresearch runtime outputs (untracked across experiments)
results.tsv
*.log
progress.png
.claude/

# Final-results folder is committed (the published artefact). Add an explicit
# negation so the standalone `results.tsv` rule above does not exclude the
# named files under results/.
!results/
!results/*.tsv
# But: per-run audit dumps from api.py / eval_only stay local-only. The grep
# block in run.log is the canonical record; results/ holds only the curated
# KEEP/DISCARD ledger TSVs.
results/per_outcome_*.tsv
results/multi_horizon_*.tsv

# Model checkpoints (large, rebuilt each experiment)
emr_model/checkpoints/

# Raw data (large source files)
emr_model/data/source/

# uv lock file (regenerate with: uv lock)
uv.lock
PLAN_TOMORROW.md
PROPOSAL_*.md
